# GCP Configuration
GCP_PROJECT=your-gcp-project-id
GCP_LOCATION=us-central1

# AlloyDB Connection
ALLOYDB_HOST=your-alloydb-private-ip
ALLOYDB_PORT=5432
ALLOYDB_DB=pragati
ALLOYDB_USER=postgres
ALLOYDB_PASS=your-password

# Optional: AlloyDB Auth Proxy (for Cloud Run)
# Set ALLOYDB_HOST to 127.0.0.1 and run the auth proxy as a sidecar
ALLOYDB_INSTANCE=projects/YOUR_PROJECT/locations/us-central1/clusters/pragati-cluster/instances/pragati-primary
